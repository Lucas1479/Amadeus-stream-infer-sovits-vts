# =============================================================================
# .env.example — 配置模板，复制为 .env 并填入真实值
# 所有带 <...> 的占位符必须替换；带默认值的可按需修改
# =============================================================================

# ── LLM : DeepSeek ───────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=<your-deepseek-api-key>
DEEPSEEK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ── LLM : Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL_NAME=gemini-2.5-flash

# ── LLM : AWS Bedrock ────────────────────────────────────────────────────────
AWS_BEARER_TOKEN_BEDROCK=<your-bedrock-bearer-token>
AWS_BEDROCK_REGION=us-west-2
AWS_BEDROCK_MODEL_ID=deepseek.v3-v1:0
AWS_BEDROCK_USE_INFERENCE_PROFILE=false
AWS_BEDROCK_INFERENCE_PROFILE_ID=
AWS_BEDROCK_USE_CACHE=true
AWS_BEDROCK_CACHE_TTL=3600
AWS_BEDROCK_CONNECTION_POOL_SIZE=10
AWS_BEDROCK_MAX_KEEPALIVE=5
AWS_BEDROCK_KEEPALIVE_EXPIRY=60.0

# ── 本地 LLM ─────────────────────────────────────────────────────────────────
# USE_LOCAL_LLM=false 时以下配置不生效
USE_LOCAL_LLM=false
LOCAL_LLM_TYPE=llama_server        # llama_server | lmstudio | ollama | cli
LOCAL_LLM_MODEL=<model-alias>
LOCAL_LLM_URL=http://127.0.0.1:8080/v1
LM_STUDIO_URL=http://localhost:1234

# llama-server 可执行文件完整路径（Windows 示例）
LOCAL_LLM_CLI_PATH=C:\path\to\llama-server.exe

# llama-server 启动参数（各字段单独配置）
LOCAL_LLM_CLI_MODEL_PATH=C:\path\to\model.gguf
LOCAL_LLM_CLI_PORT=8080
LOCAL_LLM_CLI_THREADS=12
LOCAL_LLM_CLI_CONTEXT=4096
LOCAL_LLM_CLI_NGL=0               # GPU 层数，0 = 全 CPU

# ── RAG ──────────────────────────────────────────────────────────────────────
RAG_ENABLED_FOR_LOCAL=true
RAG_TOP_K=1
RAG_MAX_DISTANCE=0.25

# ── VTS ──────────────────────────────────────────────────────────────────────
VTS_WS_URL=ws://127.0.0.1:8001
VTS_TOKEN_FILE=vts_auth_token.json

# ── TTS 模型路径（相对于项目根目录，或绝对路径）────────────────────────────────
TTS_DEVICE=cuda                    # cuda | cpu
TTS_GPT_MODEL_PATH=GPT_weights_v3/<your-gpt-model>.ckpt
TTS_SOVITS_MODEL_PATH=SoVITS_weights_v3/<your-sovits-model>.pth

# ── TTS 管线调优 ──────────────────────────────────────────────────────────────
SEGMENT_CHAR_LIMIT=140
USE_EXPERIMENTAL_TTS_STREAM=true
EXP_TTS_MAX_CONCURRENCY=2
USE_FIRST_SENTENCE_SPRINT=false
DISPLAY_FALLBACK_WINDOW_SEC=1.5

# ── OpenClaw ─────────────────────────────────────────────────────────────────
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=<your-openclaw-token>
# OpenClaw 项目根目录（含 scripts/run-node.mjs 的目录）
OPENCLAW_PROJECT_DIR=C:\path\to\openclaw
